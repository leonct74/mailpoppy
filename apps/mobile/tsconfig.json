{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["node", "react"],
    "paths": {
      "@mailpoppy/core": ["../../packages/core/src"],
      "@mailpoppy/api-client": ["../../packages/api-client/src"]
    }
  },
  "include": ["App.tsx", "index.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "android", "ios"]
}
