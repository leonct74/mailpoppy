{
  "name": "@mailpoppy/desktop-sidecar",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:backend": "node scripts/build-backend-bundle.mjs",
    "gen:manifest": "tsx scripts/build-manifest.ts",
    "verify:backend": "node scripts/verify-backend-reproducible.mjs",
    "test": "node --test scripts/lib/*.test.mjs",
    "predev": "npm run gen:backend",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "prebuild:binary": "npm run gen:manifest",
    "build:binary": "node scripts/build-sidecar.mjs",
    "pretypecheck": "npm run gen:backend",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3.700.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1060.0",
    "@aws-sdk/client-dynamodb": "^3.1058.0",
    "@aws-sdk/client-iam": "^3.1057.0",
    "@aws-sdk/client-route-53": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ses": "^3.700.0",
    "@aws-sdk/client-sesv2": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.1058.0",
    "@mailpoppy/core": "*",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.0",
    "imapflow": "^1.3.5",
    "mailparser": "^3.9.9"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.0.0",
    "esbuild": "0.28.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
