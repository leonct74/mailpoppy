{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mailpoppy",
  "version": "0.1.6",
  "identifier": "com.mailpoppy.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run build:sidecar && npm run dev",
    "beforeBuildCommand": "npm run build:sidecar && npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mailpoppy",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false,
        "backgroundColor": "#020617"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/mailpoppy-sidecar"]
  }
}
